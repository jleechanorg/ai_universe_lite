{
  "name": "@ai-universe-lite/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern='src/test/.*\\.test\\.ts$'",
    "test:integration": "jest --testPathPattern='src/test/.*\\.integration\\.test\\.ts$' --runInBand",
    "test:gem-builder": "jest --testPathPattern='src/test/gem-builder/'",
    "gem:e2e": "jest --testPathPattern='src/test/gem-builder/.*\\.e2e\\.test\\.ts$' --runInBand",
    "gem:meta-eval": "tsx src/agents/meta-eval.ts",
    "prepare:shared-libs": "bash scripts/prepare_shared_libs.sh"
  },
  "dependencies": {
    "@ai-universe/mcp-server-utils": "file:../shared-libs/packages/mcp-server-utils",
    "@ai-universe/gem-runtime": "file:../shared-libs/packages/gem-runtime",
    "@google-cloud/firestore": "^7.0.0",
    "@google-cloud/secret-manager": "^4.0.0",
    "@google-cloud/storage": "^7.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.19.0",
    "fastmcp": "^1.0.0",
    "firebase-admin": "^12.0.0",
    "jose": "^5.0.0",
    "nanoid": "^5.0.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "semver": "^7.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
