# ai-rpg gem — environment template
# Copy this file to .env and fill in the values you need locally.
# Real values are loaded from GCP Secret Manager in deployed environments.

# === Required at runtime ===
GEM_ID=ai-rpg
GEM_VERSION=0.1.0
REF_BUCKET=ai-universe-lite-refs
PORT=8080

# === Optional: LLM keys (only used by tools that call the LLM) ===
# When unset, ctx.callLlm returns an empty string and tools fall back to deterministic output.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# === Local dev overrides ===
# NODE_ENV=development
# MCP_SESSION_STORE=memory
