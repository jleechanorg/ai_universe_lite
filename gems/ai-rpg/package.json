{
  "name": "@ai-universe-lite/gem-ai-rpg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "v1 reference gem for AI Universe Lite: tabletop RPG co-GM with dice, character sheets, combat, world state, and narration tools",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch"
  },
  "dependencies": {
    "@ai-universe/gem-runtime": "file:../../shared-libs/packages/gem-runtime",
    "@ai-universe/mcp-server-utils": "file:../../shared-libs/packages/mcp-server-utils",
    "fastmcp": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
