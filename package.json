{
  "name": "ai_universe_lite",
  "version": "0.1.0",
  "private": true,
  "description": "Gem registry + builder for AI Universe — shareable MCP servers from a prompt",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "backend",
    "shared-libs/packages/*",
    "packages/*"
  ],
  "scripts": {
    "prepare:shared-libs": "cd backend && npm run prepare:shared-libs",
    "build": "npm run build --workspaces --if-present",
    "build:backend": "cd backend && npm run build",
    "type-check": "npm run type-check --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:gem-builder": "cd backend && npm run test:gem-builder",
    "gem:e2e": "cd backend && npm run gem:e2e",
    "gem:meta-eval": "cd backend && npm run gem:meta-eval",
    "dev": "cd backend && npm run dev",
    "start": "cd backend && npm run start"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^22.0.0",
    "npm-run-all": "^4.1.5"
  }
}
